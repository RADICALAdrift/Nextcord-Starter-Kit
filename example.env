# Copy this file to .env and fill in the required values
# Discord Bot Variables
BOT_TOKEN=
# You can obtain a token by creating an application/bot user on the Discord Developer Portal
OWNER_ID=
# Enable Developer Mode in Discord settings to copy your user ID

# Cog Loader Variables
COG_CODE=
# Used for the bot's load/reload/unload commands
COG_DIR=./cogs
# Path to your cogs folder relative to the bot directory, Recommended: do not edit

# All Variables stored below are optional and used by cogs (Standard bot cogs are server.py, start.py, status.py) 

# Github Autoupdater Variables
NEXIC_DATA_BRANCH=main
NEXIC_DATA_REPO=
# Example:
# https://USERNAME:github_pat_TOKEN@github.com/USERNAME/REPOSITORY.git
# Generate a fine-grained personal access token here:
# https://github.com/settings/personal-access-tokens

# Twitch Discord Variables
AUTOLIVE_CHANNEL_ID=
AUTOLIVE_CHANNEL_ID_VTUBER=
AUTOLIVE_ROLE_ID_MAIN=
AUTOLIVE_ROLE_ID_VTUBER=

# Twitch API Credentials
TWITCHLIVE_CLIENT_ID=
TWITCHLIVE_CLIENT_SECRET=

# Auto managed by the bot, do not edit
TWITCHLIVE_TOKEN=
TWITCHLIVE_TOKEN_EXPIRES_AT=